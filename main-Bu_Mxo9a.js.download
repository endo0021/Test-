me:"size-5",strokeWidth:1.5})]}),ft.jsxs("div",{className:"flex-1 flex flex-col gap-1",children:[ft.jsx("h6",{className:"text-text-primary text-sm m-0 font-normal",children:e.message}),e.description&&ft.jsx("div",{className:"text-text-tertiary text-sm m-0 font-normal",children:e.description})]}),ft.jsx(uF,{icon:ft.jsx(mC,{className:"size-4"}),size:"xs",rank:"tertiary","aria-label":"Close toast",onClick:()=>t(e.id)})]})}finally{n.f()}}function hee(){var e=Xd(1);try{const{messages:e,removeToast:t}=WT();return 0===e.length?null:ft.jsx("div",{className:"fixed top-12 right-3 z-9999 max-w-[420px] w-auto flex flex-col gap-3 sm:top-2 sm:right-2 sm:left-2 sm:max-w-none md:left-auto md:right-2","data-testid":"toast-container",children:e.map((e=>ft.jsx(pee,{toast:e,onRemove:t},e.id)))})}finally{e.f()}}const mee=({redirect:e})=>{var t=Xd(1);try{const t=Da();return jr.useEffect((()=>{const n=setTimeout((()=>{const n=_G(e,Hk,Bk.SignIn);t(n)}),2e3);return()=>{clearTimeout(n)}}),[t,e]),ft.jsx("p",{className:"text-text-tertiary text-xs",children:"Redirecting..."})}finally{t.f()}},fee=({redirect:e})=>{var t=Xd(1);try{const t=Da();return ft.jsx(cF,{rank:"cta",size:"xl",className:"mt-4",onClick:()=>t(e?zA(Bk.SignIn,{},{redirect:e}):Bk.SignIn),iconAppend:ft.jsx(_N,{}),children:"Sign in"})}finally{t.f()}},gee=()=>{var e=Xd(1);try{const e=Da();return ft.jsx(cF,{rank:"primary",size:"m",className:"mt-4",onClick:()=>e(Bk.SettingsPersonalDetails),children:"Go to Settings"})}finally{e.f()}};function yee(){var e=Xd(1);try{const{sectionRef:e,isVisible:t}=QF();return ft.jsxs("section",{ref:e,className:`${YF(t)} box-border flex flex-col justify-center items-center gap-10 overflow-hidden max-w-7xl mx-auto w-full pt-30 pb-10 px-4 text-center`,children:[ft.jsxs("h1",{className:"m-0 font-display text-4xl sm:max-w-230 sm:mx-auto sm:text-5xl lg:text-6xl font-medium text-text-primary",children:["Create the future internet,",ft.jsx("br",{className:"lg:block hidden"})," one app at a time"]}),ft.jsx("div",{className:"sm:max-w-165 mx-auto",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary text-left px-4",children:"Chat with AI on Caffeine to create apps and websites. Our AI builds on a new open tech stack designed to power apps that are self-writing, which grants them incredible security and resilience, and provides a guarantee that a mistake during a software update cannot cause data loss. AI writes your backend software using Motoko, the first programming language for AI, and runs your apps on the revolutionary Internet Computer network (ICP)."})})]})}finally{e.f()}}function xee(){var e=Xd(1);try{const{sectionRef:e,isVisible:t}=QF(),{sectionRef:n,isVisible:r}=QF(),{sectionRef:a,isVisible:s}=QF();return ft.jsxs("section",{className:"box-border px-4 pb-32 pt-16 flex flex-col gap-12 max-w-165 w-full mx-auto",children:[ft.jsxs("div",{ref:e,className:`${YF(t)} flex flex-col gap-12`,children:[ft.jsx("h2",{className:"m-0 font-display text-2xl sm:text-3xl font-medium text-text-primary",children:"What is the Caffeine platform"}),ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:['Caffeine is an online platform that makes it possible to create and maintain successful apps and websites, simply by chatting with AI. Because only chat is required, Caffeine is a platform for "self-writing apps."',ft.jsx("br",{}),ft.jsx("br",{}),'The platform unlocks a future where a large portion of the world\'s apps, websites and even enterprise systems, are eventually self-writing. On one hand, businesses will use self-writing apps to address common needs such as CRM (customer relationship management), ERP (enterprise resource planning), workflow management, and e-commerce. On the other hand, consumers will pioneer new paradigms, for example creating highly custom "hyperlocal" social media and e-sports functionality for usage by extended families and friend groups, as well as apps for simple needs such as handling the RSVPs for a wedding, or hosting the resulting photos.',ft.jsx("br",{}),ft.jsx("br",{}),"Self-writing platforms will eventually power the creation and operation of hundreds of millions of apps, and become a dominant segment of the tech industry. They can reduce development costs and time to market by thousands of times, placing non-technical users in the driving seat, whether in business, entrepreneurial activities, or our private lives.",ft.jsx("br",{}),ft.jsx("br",{}),"Caffeine is designed to work for both mobile and desktop users. Today, more than 5 billion people own smartphones, and one day, many of them will create their own apps as a matter of course."]})]}),ft.jsx("div",{ref:n,className:`${YF(r)} w-full overflow-hidden`,children:ft.jsx(RF,{src:"https://cdn.caffeine.ai/assets/about-hero-BC0ruNu_.webp",responsiveWidth:"640 md:920",alt:"Caffeine platform overview hero",deferUntilVisible:!0,className:"m-0 w-full h-auto object-cover"})}),ft.jsx("div",{ref:a,className:YF(s),children:ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:["Create through instant messaging",ft.jsx("br",{}),ft.jsx("br",{}),"The Caffeine.ai user experience is very similar to that on instant messaging services like WhatsApp and Signal. However, on Caffeine, users chat with AI, and each individual chat relates to a specific app they are creating or updating. In their chats, users provide instructions about features to create, or modifications to make, and after the AI has worked for a short while, their app makes its first appearance, or is updated, on its URL.",ft.jsx("br",{}),ft.jsx("br",{}),"Update production apps with ease",ft.jsx("br",{}),ft.jsx("br",{}),'Through chats, users update their apps in "draft" mode, with their instructions causing new versions of their draft app to be created. At any time, they can decide to push the features of their current draft app to their "live" app. The AI then takes care of updating the live version of their app so that it has the same features as the draft version, without the user having to do anything technical.',ft.jsx("br",{}),ft.jsx("br",{}),"The world's first self-writing tech stack",ft.jsx("br",{}),ft.jsx("br",{}),'Some vibe coding platforms, such as Lovable and Replit, also now target "no code" vibe coding, which is essentially self-writing. However, there are large differences in how Caffeine approaches the self-writing challenge, and differences in the results achieved.',ft.jsx("br",{}),ft.jsx("br",{}),"Caffeine uses a new tech stack to create and host apps, which is designed as a force-multiplier for AI working in the role of tech team, and provides safety guarantees. For instance, on Caffeine, the AI writes backend software using a new programming language for AI called Motoko, which increases the sophistication of the apps that AI can construct, while also preventing data from being accidentally lost when they are updated."]})})]})}finally{e.f()}}const vee=[{version:"1.0",header:"AI's software writing abilities are force-multiplied",content:"Frontier foundation AI models are becoming better at writing code, thanks to massive industry-wide investments. However, whatever the current state of advancement, it is always desirable that the AI can write backend code that is more correct, and more sophisticated. We always want more, and our ambitions for apps will also be unbounded.\n\nThe Motoko programming language leverages powerful new technology to enable AI to create better software and therefore better apps. Given any backend requirement for an app, Motoko enables AI to achieve the required results by writing substantially less complex software, using code that gels better with its linguistic abstract reasoning patterns.",image:"https://cdn.caffeine.ai/assets/about-manifest-1-DQNC-oRJ.webp"},{version:"2.0",header:"Strong safety-rails provide strong guarantees",content:"On self-writing platforms, app owners iteratively instruct AI on what app features and changes are needed by interacting over chat. In this new model of software development, the AI works thousands of times faster than humans, with speed a key determinant of user experience.\n\nWith such demands, it is no surprise that AI inevitably makes mistakes, and AI can also hallucinate. While the AI can iterate to fix mistakes, crucially the app exists without the safety net of a human team to help with emergencies when things go wrong.\n\nConsequently, self-writing platforms designed to support the creation of successful production apps, rather than just experimental prototypes, must provide hard guarantees with regards to requirements such as data safety, resistance to cyber attacks, and resilience.",image:"https://cdn.caffeine.ai/assets/about-manifest-2-D34A6Civ.webp"},{version:"2.1",header:"Guaranteed — app updates don't lose data",content:'A key challenge involved with updating apps after they are in production and being applied for purpose, is that updates often require app data to be "migrated" in complex ways that change its structure. When such migrations are performed, there is always a risk that some of the data will be lost, which is a hard challenge to overcome, especially in the context of self-writing.\n\nFor example, a business might update the features of a crucial CRM (customer relationship management) app, with the update causing subtle data loss that isn\'t noticed at first. They might then continue using the app and entering new data, only detecting the problem later — by which time a simple rollback is impractical, since this would cause the loss of new data.\n\nData loss is unacceptable, even in consumer contexts. For example, imagine a user storing their important files on a sovereign online storage drive they created, or an extended family that creates a hyperlocal social network, which comes to hold some of their most important memories.\n\nCaffeine addresses this critical challenge in various ways. A key part of the solution involves the Motoko programming language framework. When the AI proposes an app update, the Motoko framework first applies advanced computer science to determine whether the update might cause data loss. Faulty updates are simply rejected, causing the AI to re-writes its update and try again — guaranteeing safety. Currently, the major self-writing platforms built on traditional technology stacks are unable to provide this protection for app data.',image:"https://cdn.caffeine.ai/assets/about-manifest-3-Co03SXx0.webp"},{version:"2.2",header:"Guaranteed — safety from traditional cyber attacks",content:'The traditional tech stacks that power the backend of apps are insecure. They are composed from an operating system, such as Linux or Windows Server, and various platform components including databases, such as MySQL, and application servers, such as Node.js. They can be run on clouds, such as Amazon Web Services, or bare metal servers in data centers.\n\nThe core challenge is that the misconfiguration of a component, some badly written custom software logic, or a software update containing malware, can allow hackers break out into the operating system, from where they can work to exfiltrate data, or encrypt the platform components using ransomware. Cybersecurity systems such as firewalls and anti-malware add some protection, but are fallible.\n\nThis is a double challenge for self-writing platforms and their users. On the one hand, self-writing will cause the number of apps on the internet to explode, making it completely impractical to protect them all using human cybersecurity teams. On the other hand, AI has to perform its work fast, and can make mistakes that create security vulnerabilities.\n\nCaffeine addresses this by building on a new kind of open cloud created by a mathematically secure network (which results from a seminal inventive step, and hundreds of millions of dollars of R&D work). The cloud platform involved runs a new form of "serverless" software that combines logic and data, and is also "tamperproof."On the backend, apps are composed entirely from this tamperproof serverless software. No escape to the operating system is possible, because there isn\'t one — app code runs within a secure network protocol. Moreover, because the protocol is mathematically secure, it can guarantee that only the correct app logic will run, and that it always runs against data that it has processed.\n\nBecause the code and data of apps created using Caffeine are tamperproof, the apps can run without traditional cybersecurity protections such as firewalls, anti-malware and anti-intrusion systems.\n\nMeanwhile, after numerous security failures related to vibe coding, other major self-writing platforms are trying to rise to the challenge by developing their own proprietary cloud platforms to host apps, and taking on responsibility for app cybersecurity themselves. However, this has two drawbacks: firstly, app owners must trust them to maintain the security of their platform, and secondly, they must accept being locked into their proprietary platform forever.\n\nImportant note: another important form of security vulnerability can occur when AI incorrectly designs features. For example, on a blogging app, it might mistakenly place a delete button on blog posts by default, when such functionality should only be available to administrators of the blog. Caffeine also leads in preventing this kind of problem.',image:"https://cdn.caffeine.ai/assets/about-manifest-4-CSOUtDn7.webp"},{version:"2.3",header:"Guaranteed — apps are always available",content:"Another key challenge involves ensuring apps are resilient and always available for end users. Caffeine already addresses the security dimension of this challenge by ensuring apps cannot be encrypted by ransomware, which prevents apps running, but there are other dimensions to the challenge too.\n\nIt's well known that a server computer can suffer a power outage, be disconnected from the internet, simply break, or otherwise crash. Moreover, its software can get misconfigured, or suffer eventualities such as log files consuming all available disk space preventing new data being stored. In short, systems built on traditional tech stacks are unreliable by default.\n\nTo address the challenge of resilience, apps built on traditional tech stacks must incorporate complex mechanisms to allow for failover, which often involves replicating apps across multiple server instances using frameworks such as Kubernetes, and running their databases in multi-node configurations. However, such complexity equals fragility when development is automated by AI, which is another reason that major self-writing services are now building their own proprietary cloud platforms to host the apps they create, with the consequential aforementioned need for trust, and vendor lock-in issues.\n\nBy contrast, Caffeine builds on an open cloud-from-network platform, which guarantees that the serverless software that powering the apps will run, and that its data will be available (within the fault bounds of the network configuration).\n\nThe advantage is twofold: on the one hand AI does not have to handle the complexity of failover and resilience, allowing its intelligence quotient to be directed to more useful work, and on the other, apps are made far more reliable, and the need for app owners to trust Caffeine is reduced.",image:"https://cdn.caffeine.ai/assets/about-manifest-5-KeALz8hF.webp"},{version:"3.0",header:"Apps can scale without code changes or interruption",content:'Scaling the capacity of an app with its usage is a hard challenge when apps are built on traditional tech stacks. For example, a popular website might need to serve more pages, a complex social network might need to process more database operations, an online file storage app might need more disk space, and an image processing service might need more raw computing power.\n\nWhen apps are built on traditional tech stacks, meeting scaling needs often adds substantial complexity to the software involved, similarly to the aforementioned app resilience challenges. Meeting scaling needs thus inevitably requires more work from AI, and again consumes intelligence quotients that are better directed towards creating features and value, while also increasing the risk of mistakes.\n\nHere, the open serverless cloud platform technology targeted by Caffeine provides a unique solution. When apps begin to have scaling needs, either due to increased usage, or high variability in usage patterns, Caffeine can deploy apps to a feature known as an "Engine" (feature scheduled for availability in Q2 2026).\n\nWhen hosted on an Engine, an app can usually be scaled without modification, or interruption, simply by adjusting the number and type of network nodes powering the Engine.\n\nNote: the network Caffeine already uses the technology described behind the scenes, but its forthcoming Engine feature will allow app scaling needs to be finely tuned on a per-app basis.',image:"https://cdn.caffeine.ai/assets/about-manifest-6-C3COASgv.webp"},{version:"4.0",header:"Apps are sovereign and portable, without lock-in",content:"A key concern of all app owners is vendor lock-in. Because Caffeine builds apps on an open technology stack, they are both sovereign and portable.\n\nIn default usage, Caffeine deploys apps to a public cloud network that employs TEE technology to protect privacy. However, in 2026, new open source products based on the same revolutionary technology will allow users to run their apps on private cloud networks, which run on servers of their owner's choosing, and on single cloud instances and server machines (in special cases where apps being tamperproof, resilient to server failure, and auto-scaling, are not major concerns).\n\nThe sovereignty and portability provided by Caffeine contrasts strongly with other major self-writing services, which are turning to the use of proprietary cloud platforms that are essentially SaaS services for hosting apps, where they will remain locked forever.\n\nBy contrast, Caffeine provides app owners with absolute freedom.",image:"https://cdn.caffeine.ai/assets/about-manifest-7-DcTC0CPr.webp"},{version:"4.0",header:"Deep Web3 functionality is supported",content:"Because Caffeine builds tamperproof apps on a secure network, apps can natively interact with smart contracts on traditional blockchains, and securely process and custody their tokens (currently, this functionality is restricted, but it will be unlocked in 2026). This enables apps to interact with traditional DeFi, and also payment and financial systems based on stablecoins, which are set to become much more popular since they enable far greater automation, for example by AI agents. These will also be hosted on new blockchains operated by the likes of Stripe and Google. Thanks to the multi-chain capabilities of the secure network that Caffeine deploys apps to, apps built with Caffeine will be able to integrate with the entire ecosystem.",image:"https://cdn.caffeine.ai/assets/about-manifest-8-DLntxn0Q.webp"}];function bee({feature:e,isExpanded:t,onToggle:n}){var r=Xd(1);try{const{sectionRef:r,isVisible:a}=QF(),s=t?void 0:{display:"-webkit-box",WebkitLineClamp:8,WebkitBoxOrient:"vertical",overflow:"hidden"};return ft.jsxs("div",{ref:r,className:`${YF(a)} flex flex-col lg:flex-row gap-9 lg:gap-22.5 py-20`,children:[ft.jsxs("div",{className:"flex flex-col gap-4 md:flex-1",children:[ft.jsx("p",{className:"m-0 text-xs uppercase tracking-md text-text-primary",children:e.version}),ft.jsx("h3",{className:"m-0 font-display text-lg font-normal text-text-primary",children:e.header}),ft.jsx("p",{className:"m-0 text-md leading-6 text-text-tertiary whitespace-pre-line",style:s,children:e.content}),ft.jsx(cF,{type:"button",rank:"secondary",size:"m",className:"w-fit",iconAppend:t?ft.jsx(Sj,{}):ft.jsx(jj,{}),onClick:n,children:t?"Less":"More"})]}),ft.jsx("div",{className:"w-full lg:w-auto lg:h-77.5 shrink-0",children:ft.jsx(RF,{src:e.image,responsiveWidth:"400 md:600 lg:800",alt:e.header,deferUntilVisible:!0,className:"m-0 w-full h-auto lg:w-auto lg:h-full object-contain"})})]})}finally{r.f()}}function wee(){var e=Xd(1);try{const[e,t]=jr.useState({}),{sectionRef:n,isVisible:r}=QF();return ft.jsxs("section",{className:"box-border px-4 pb-24 pt-8 flex flex-col max-w-165 lg:max-w-7xl mx-auto",children:[ft.jsx("div",{ref:n,className:`${YF(r)} flex flex-col gap-6 pb-6`,children:ft.jsx("p",{className:"m-0 text-xs uppercase tracking-md text-text-tertiary",children:"The new stack for AI that Caffeine applies has the following advantages:"})}),ft.jsx("div",{className:"flex flex-col",children:vee.map(((n,r)=>{const a=e[r]??!1;return ft.jsx(bee,{feature:n,isExpanded:a,onToggle:()=>t((e=>({...e,[r]:!a})))},`${n.header}-${r}`)}))})]})}finally{e.f()}}const kee=()=>{var e=Xd(1);try{return ft.jsx(lS,{})}finally{e.f()}},Eee=[{route:Bk.About,element:()=>ft.jsx(Qa,{to:Bk.AboutNext,replace:!0})},{route:Bk.AboutNext,element:function(){var e=Xd(1);try{const e=Da(),{sectionRef:t,isVisible:n}=QF();return ft.jsxs("div",{className:"flex flex-col overflow-x-hidden text-text-primary flex-1 overflow-y-auto",children:[ft.jsx("style",{children:KF()}),ft.jsxs("main",{className:"flex-1 z-10 flex flex-col overflow-x-hidden relative",children:[ft.jsx(yee,{}),ft.jsx(xee,{}),ft.jsx(wee,{}),ft.jsx(DF,{heading:"Create with us",description:"We are growing a team that is curious, fast moving and deeply focused on quality.",buttonText:"Explore open roles",dataActionName:"About page CTA start building",onClick:()=>e(Bk.Careers),contentWrapperRef:t,contentWrapperClassName:`${YF(n)} flex flex-col items-center gap-9 w-full`})]}),ft.jsx(VF,{})]})}finally{e.f()}}},{route:Bk.Careers,element:function(){var e=Xd(1);try{const{sectionRef:e,isVisible:t}=QF();return ft.jsxs("div",{className:"flex flex-col overflow-x-hidden text-text-primary flex-1 overflow-y-auto",children:[ft.jsx("style",{children:KF()}),ft.jsxs("main",{className:"flex-1 z-10 flex flex-col overflow-x-hidden relative",children:[ft.jsx(pU,{}),ft.jsx(hU,{}),ft.jsx(mU,{}),ft.jsx(fU,{}),ft.jsx(DF,{heading:"Don’t see a role that fits?",description:"Get in contact with us and let us know what you could bring to the team",buttonText:"Spontaneous application",dataActionName:"Careers page CTA email",onClick:()=>{window.location.href="mailto:careers@caffeine.ai"},contentWrapperRef:e,contentWrapperClassName:`${YF(t)} flex flex-col items-center gap-9 w-full`})]}),ft.jsx(VF,{})]})}finally{e.f()}}},{route:Bk.Affiliate,element:function(){var e=Xd(1);try{const[e,t]=jr.useState(!1),{sectionRef:n,isVisible:r}=QF();return ft.jsxs("div",{className:"flex flex-col overflow-x-hidden text-text-primary flex-1 overflow-y-auto",children:[ft.jsx("style",{children:KF()}),ft.jsxs("main",{className:"flex-1 z-10 flex flex-col overflow-x-hidden relative",children:[ft.jsx(ZF,{onJoin:()=>t(!0)}),ft.jsx(JF,{}),ft.jsx(DF,{heading:"Curious?",description:"Be the first to know when our affiliate program launches.",buttonText:"Join waitlist",buttonIconAppend:ft.jsx(mj,{}),onClick:()=>t(!0),contentWrapperRef:n,contentWrapperClassName:`${YF(r)} flex flex-col items-center gap-9 w-full`})]}),ft.jsx(VF,{}),ft.jsx(CF,{isOpen:e,onClose:()=>t(!1)})]})}finally{e.f()}}},{route:Bk.Press,element:function(){var e=Xd(1);try{return ft.jsxs("div",{className:"flex flex-col overflow-x-hidden text-text-primary flex-1 overflow-y-auto",children:[ft.jsx("style",{children:KF()}),ft.jsxs("main",{className:"flex-1 z-10 flex flex-col overflow-x-hidden relative",children:[ft.jsx(BU,{}),ft.jsx(HU,{}),ft.jsx(qU,{}),ft.jsx(VU,{})]}),ft.jsx(VF,{})]})}finally{e.f()}}},{route:Bk.Contact,element:function(){var e=Xd(1);try{const{sectionRef:e,isVisible:t}=QF();return ft.jsxs("div",{className:"flex flex-col overflow-x-hidden text-text-primary flex-1 overflow-y-auto",children:[ft.jsx("style",{children:KF()}),ft.jsxs("main",{className:"flex-1 flex flex-col overflow-x-hidden relative max-w-7xl mx-auto w-full",children:[ft.jsx(gU,{}),ft.jsx(dU,{embedUrl:"https://www.youtube.com/embed/JKQHPLjMp7U?autoplay=1&rel=0",posterSrc:bR,title:"Caffeine demo preview",sectionClassName:"flex flex-col items-center pt-20 pb-24 px-4 w-full",mediaWrapperRef:e,mediaWrapperClassName:`${YF(t)} w-full py-3 sm:py-9`})]}),ft.jsx(VF,{})]})}finally{e.f()}}},{route:Bk.Pricing,element:function(){var e=Xd(1);try{return ft.jsxs("div",{className:"flex flex-col overflow-x-hidden text-text-primary flex-1 overflow-y-auto",children:[ft.jsx("style",{children:KF()}),ft.jsxs("main",{className:"flex-1 z-10 flex flex-col overflow-x-hidden relative",children:[ft.jsx(DU,{}),ft.jsx(UU,{})]}),ft.jsx(VF,{})]})}finally{e.f()}}},{route:Bk.License,element:function(){var e=Xd(1);try{return ft.jsxs(yU,{title:"Caffeine License Agreement",subtitle:"(“License Agreement”)",date:"Effective Date: December 17, 2025",children:[ft.jsxs(vU,{children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:'Thank you for your interest in Caffeine, a prompt-based engineering tool that utilizes third party artificial intelligence to allow you to easily create, deploy, update and manage decentralized applications on the Internet Computer ("Caffeine"). In this License Agreement the terms "You" and "Yours" refer to the person using Caffeine.'}),ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:["This License Agreement governs Your use of Caffeine."," ",ft.jsx("strong",{children:"BY CREATING AND DEPLOYING YOUR APPLICATION(S) USING CAFFEINE, YOU AGREE THAT YOU HAVE READ, UNDERSTOOD, AND AGREE TO BE BOUND BY THIS LICENSE AGREEMENT. IF YOU DO NOT AGREE, YOU MAY NOT USE CAFFEINE."})]}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"If You choose to use Caffeine, You and Caffeine Labs AG, including its affiliates and subsidiaries (collectively “Caffeine Labs”), acknowledge and agree as follows:"})]}),ft.jsx(xU,{title:"1. LIMITED LICENSE",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Subject to the terms and conditions contained in this License Agreement, Caffeine Labs grants You a limited, non-exclusive, non-transferable, non-sublicensable, revocable license to use Caffeine (including any third party wallet application, payment provider and/or corresponding credits to maintain your application(s)) only for the purposes of creating and deploying AI generated applications run by the Internet Computer."})}),ft.jsxs(xU,{title:"2. YOUR RESPONSIBILITIES",children:[ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:["You are responsible for all activities related to your use of Caffeine, regardless of whether the activities are authorized by You or undertaken by You, your employees or a third party on your behalf."," ",ft.jsx("strong",{children:"AS PART OF YOUR USE OF CAFFEINE, YOU WILL ENSURE THAT YOU DO NOT SUBMIT ANY INFORMATION THAT CONTAINS OR CONSTITUTES CONFIDENTIAL, PROPRIETARY, SENSITIVE, OR PERSONALLY IDENTIFIABLE DATA AND/OR CONTENT INTO THE PROMPT TO CREATE YOUR APPLICATION. ANYTHING YOU SUBMIT INTO THE PROMPT IS IRREVOCABLY PUBLICLY ACCESSIBLE AND READABLE IN THE UNDERLYING COMPUTER CODE."})]}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"You will not misrepresent or embellish the relationship between You and Caffeine Labs, including expressing or implying that Caffeine Labs supports, sponsors, endorses, or contributes to You or your business endeavors or Your application(s). You will not imply any relationship or affiliation with Caffeine Labs except as expressly permitted by this License Agreement. You are prohibited from using the Caffeine Labs name, logo or any other trademarks related to Caffeine Labs in any manner that may imply an endorsement or affiliation, misrepresent your relationship with Caffeine Labs or create confusion regarding the source of an application, tool or other product or service."})]}),ft.jsx(xU,{title:"3. APPLICABLE LAWS",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"You will comply with all applicable laws and regulations (including without limitation laws and regulations related to export controls and data protection) in connection with your use of Caffeine and any applications you deploy."})}),ft.jsx(xU,{title:"4. RESERVATION OF CAFFEINE LABS’ RIGHT",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Caffeine is owned by Caffeine Labs and licensed, not sold, to You. Caffeine content, visual interfaces, interactive features, information, graphics, design, compilation, computer code, products, services, and all other elements of Caffeine and related documentation, are protected by applicable intellectual property laws. As between You and Caffeine Labs, all Caffeine Labs materials and Caffeine, including intellectual property rights therein and thereto, are the sole and exclusive property of Caffeine Labs and/or its third-party licensors. For the avoidance of doubt, all content, data, graphics, design, products, services, etc created by you and/or submitted onto your application by your end users are not part of the sole and exclusive property of Caffeine Labs. Caffeine Labs reserves all rights not expressly granted in this License Agreement. You do not acquire any right, title, or interest to the Caffeine Labs materials or Caffeine, whether by implication, estoppel, or otherwise, except for the limited rights set forth in this License Agreement."})}),ft.jsx(xU,{title:"5. PROMPTING RESTRICTIONS",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"You agree that You will not provide or submit to the prompt on Caffeine any confidential information, proprietary information or personal data or personally identifiable information. You agree that You are authorized to provide any information that You submit to the prompt on Caffeine. You further understand that any information You provide or submit to the prompt on Caffeine can be viewed by others. You agree that You will not provide or submit to the prompt on Caffeine any offensive, obscene, threatening, violent, discriminatory or otherwise objectionable or unlawful information."})}),ft.jsx(xU,{title:"6. FEEDBACK",children:ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:['If You provide Caffeine Labs with any comments, ideas, bug reports, feedback, enhancements, recommendations, or modifications in relation to Caffeine ("Feedback"), such Feedback is provided on a non-confidential basis, and Caffeine Labs shall have the right to use such Feedback at its discretion, including, but not limited to the incorporation of such suggested changes into the Caffeine Labs materials, Caffeine or other services. You hereby grant Caffeine Labs a perpetual, irrevocable, transferable, sublicensable, nonexclusive license under all rights necessary to so incorporate and use your Feedback for any purpose, including to make and sell products and services, and agree to provide Caffeine Labs with any assistance required to document, perfect and maintain Caffeine Labs’s rights to the Feedback. You agree to allow Caffeine Labs to contact You for Feedback from time to time, but may opt-out by sending written notice to'," ",ft.jsx("a",{href:"mailto:support@caffeine.ai",className:"text-text-secondary underline hover:text-text-secondary",children:"support@caffeine.ai"}),"."]})}),ft.jsx(xU,{title:"7. TERMS AND TERMINATION",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"This License Agreement will remain in effect until terminated. The License Agreement, and your rights and licenses hereunder, will terminate immediately upon your breach of the License Agreement. You may terminate the License Agreement by ceasing all use of Caffeine. Caffeine Labs may terminate this License Agreement at any time for any reason, including without limitation any actual or suspected misuse or abuse by You of Caffeine or any violation of this License Agreement. Sections 3 through 14 shall survive any termination of this License Agreement."})}),ft.jsx(xU,{title:"8. WARRANTY DISCLAIMER AND LIMITATION OF LIABILITY",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:ft.jsx("strong",{children:'YOU UNDERSTAND AND AGREE THAT TO THE MAXIMUM EXTENT PERMITTED BY APPLICABLE LAW, CAFFEINE IS PROVIDED ON AN "AS IS" BASIS, WITHOUT WARRANTY OF ANY KIND TO THE MAXIMUM EXTENT PERMITTED BY APPLICABLE LAW, Caffeine Labs DISCLAIMS ALL WARRANTIES AND CONDITIONS, EXPRESS, IMPLIED, STATUTORY OR OTHERWISE, INCLUDING BUT NOT LIMITED TO IMPLIED WARRANTIES OR CONDITIONS OF FITNESS FOR A PARTICULAR PURPOSE, MERCHANTABILITY, TITLE, QUALITY, RESULTS, AND NON-INFRINGEMENT. Caffeine Labs EXPRESSLY DISCLAIMS ANY WARRANTIES OF ANY KIND WITH RESPECT TO THE ACCURACY OR FUNCTIONALITY OF CAFFEINE, AND WITH RESPECT TO THE ACCURACY, VALIDITY, OR COMPLETENESS OF ANY INFORMATION OR FEATURES (NOW AND IN THE FUTURE) MADE AVAILABLE THROUGH YOUR USE OF CAFFEINE, OR THE QUALITY OR CONSISTENCY OF CAFFEINE OR RESULTS OBTAINED THROUGH ITS USE. TO THE MAXIMUM EXTENT PERMITTED BY APPLICABLE LAW, UNDER NO CIRCUMSTANCES WILL Caffeine Labs BE LIABLE FOR ANY CONSEQUENTIAL, SPECIAL, INDIRECT, INCIDENTAL OR PUNITIVE DAMAGES WHATSOEVER ARISING OUT OF THE USE OR INABILITY TO USE AND ACCESS CAFFEINE OR Caffeine Labs MATERIALS, EVEN IF Caffeine Labs HAS BEEN ADVISED OF THE POSSIBILITY OF SUCH DAMAGES, AND NOTWITHSTANDING ANY FAILURE OF ESSENTIAL PURPOSE OF ANY LIMITED REMEDY. TO THE MAXIMUM EXTENT PERMITTED BY APPLICABLE LAW, IN NO EVENT WILL Caffeine Labs\'S AGGREGATE LIABILITY FOR DAMAGES ARISING OUT OF THIS LICENSE AGREEMENT OR YOUR USE OR INABILITY TO USE CAFFIENE EXCEED 100 CHF.'})})}),ft.jsx(xU,{title:"9. INDEMNITY",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"You agree to indemnify, defend and hold Caffeine Labs and its affiliates, officers, directors, suppliers, licensors, and other customers harmless from and against any and all liability and costs, including reasonable attorneys' fees incurred by such parties, in connection with or arising out of your application(s), any use by third parties of your application, your use or misuse of Caffeine, or your violation of this License Agreement or any applicable law or regulation."})}),ft.jsx(xU,{title:"10. GOVERNING LAW; VENUE",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Any claim relating to Caffeine shall be governed by the laws of Switzerland, to the exclusion of the rules on conflicts of laws. Any claim or dispute related to this License Agreement or in relation to it shall (including for non-contractual disputes or claims and their interpretation) be subject to the exclusive jurisdiction of the Courts of Zug, Switzerland, subject to an appeal at the Swiss Federal Court."})}),ft.jsx(xU,{title:"11. ENTIRE AGREEMENT AND SEVERABILITY",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"This License Agreement is the entire agreement between You and Caffeine Labs, and supersedes any and all prior agreements, negotiations, or other communications between You and Caffeine Labs, whether oral or written, with respect to the subject matter hereof. Caffeine Labs may make changes to this License Agreement when new versions of Caffeine are made available. In the event that any provision of this License Agreement is held to be invalid or unenforceable, then: (a) such provision shall be deemed reformed to the extent strictly necessary to render such provision valid and enforceable, or if not capable of such reformation shall be deemed severed from this License Agreement; and (b) the validity and enforceability of all of the other provisions hereof, shall in no way be affected or impaired thereby."})}),ft.jsx(xU,{title:"12. ASSIGNMENT",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"You may not assign this License Agreement without the prior written consent of Caffeine Labs, whether expressly or by operation of law, including in connection with a merger or change of control, and any such attempted assignment shall be void and of no effect. Caffeine Labs may assign this License Agreement without restriction and without any notice to You. Subject to the foregoing, this License Agreement shall be binding on the parties and their respective successors and permitted assigns."})}),ft.jsx(xU,{title:"13. NO WAIVER",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"The failure to exercise, or delay in exercising, a right, power, or remedy provided in this License Agreement or by law shall not constitute a waiver of that right, power, or remedy. Caffeine Labs' waiver of any obligation or breach of this License Agreement shall not operate as a waiver of any other obligation or subsequent breach of the License Agreement."})}),ft.jsx(xU,{title:"14. ENGLISH VERSION",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"The English language version of this License Agreement shall be the official and controlling version of the agreement if any conflict should arise. All communications and notices made pursuant to this License Agreement must be in the English language."})})]})}finally{e.f()}}},{route:Bk.Manifesto,element:function(){var e=Xd(1);try{const e=Da(),t=()=>{e(Bk.About)};return ft.jsxs("div",{className:"manifesto-page",children:[ft.jsxs("svg",{className:"outline-svg",viewBox:"0 0 1920 1080",fill:"none",xmlns:"http://www.w3.org/2000/svg",children:[ft.jsx("defs",{children:ft.jsxs("filter",{id:"glow",x:"-50%",y:"-50%",width:"200%",height:"200%",children:[ft.jsx("feGaussianBlur",{stdDeviation:"3",result:"coloredBlur"}),ft.jsxs("feMerge",{children:[ft.jsx("feMergeNode",{in:"coloredBlur"}),ft.jsx("feMergeNode",{in:"SourceGraphic"})]})]})}),ft.jsx("path",{d:"M0 0L1920 0L1920 1080L0 1080L0 0Z",fill:"url(#paint0_linear_0_1)",filter:"url(#glow)"})]}),ft.jsx("main",{className:"manifesto-main",children:ft.jsx("div",{className:"manifesto-content",children:ft.jsxs("div",{className:"manifesto-content-inner",children:[ft.jsx("div",{className:"manifesto-header",children:ft.jsx("button",{onClick:t,"data-dd-action-name":"Go back",className:"manifesto-back-button",children:"← Back"})}),ft.jsxs("div",{className:"manifesto-body",children:[ft.jsx("h1",{className:"manifesto-title",children:"The Self-Writing Internet Manifesto"}),ft.jsxs("section",{className:"manifesto-section",children:[ft.jsx("h2",{className:"manifesto-section-title",children:"Introducing Self-Writing Internet"}),ft.jsx("p",{className:"manifesto-text",children:"What if anybody could imagine a website, online app or service, and create it by having a natural language conversation with AI? What if this online functionality simply appears on URLs, available for immediate use, and can be improved through continued conversation? What if talking can create and update serious production services—which might support large numbers of users or customers—under the auspices of a guarantee that changes and updates made by AI at the speed of chat will never result in an accidental loss of data?"}),ft.jsx("p",{className:"manifesto-text",children:'This is the brave new world of "self-writing apps," an extension of the popular "vibe coding" paradigm, where human developers work in partnership with AI that has been integrated into their tools. Self-writing is different because apps and services are created, end-to-end, solely through natural language conversations with AI, enabling non-technical people with internet access to take on the role of entire technical teams.'}),ft.jsx("p",{className:"manifesto-text",children:'An important variant of the "self-writing apps" paradigm is the "self-writing internet." This envisions a world where the online functionality we use everyday is increasingly created through these conversations. Part of the vision is that websites, apps and services, often run on secure decentralized networks, as a part of the public internet, rather than on closed proprietary platforms such as cloud services.'}),ft.jsx("p",{className:"manifesto-text",children:"In this vision, online functionality is sovereign because app creators own the underlying software and data, and further, their apps cannot be switched off by proprietary platform operators that might withhold service or change their terms."})]}),ft.jsxs("section",{className:"manifesto-section",children:[ft.jsx("h2",{className:"manifesto-section-title",children:"Worldwide Social Impact"}),ft.jsx("p",{className:"manifesto-text",children:"The self-writing internet has the potential to unlock tremendous opportunity and change."}),ft.jsx("p",{className:"manifesto-text",children:"Individuals will find they can create exciting new forms of online functionality, such as hyperlocal social networks for exclusive use by their extended family, where they can add large and goofy emoji reactions to photos in a shared gallery, or create hyperlocal esports, where they might compete with friends for a prize of digital assets. Such new forms of online functionality will quickly follow the mass production of baseline functionality such as personal branding websites, and party-planning portals, as non-technical people get to grips with their newfound engineering superpowers."}),ft.jsx("p",{className:"manifesto-text",children:"An entrepreneur who lacks capital will finally be able to launch the Web3 sharing economy app they want to bring to life. Small and medium-sized businesses will create and update superior e-commerce experiences while incurring a tiny fraction of the cost and time involved before. Enterprise will apply the paradigm to create things like CRM and ERP. School districts will find they can quickly create the fundraising platform they couldn't afford, and an NGO will quickly create a system to assist refugees as part of a rapid response to a natural disaster. There are infinite possibilities."}),ft.jsx("p",{className:"manifesto-text",children:"Meanwhile, the paradigm will bring unparalleled benefits to the developing world. There, governments and enterprises often cannot afford to get locked into foreign SaaS services, which also present them with sovereignty challenges, while at the same time lacking sufficient home-grown technology expertise to build what they need for themselves. Even when they can build what they need, a key additional challenge is that they lack the cybersecurity expertise to keep their functionality and data safe from threats, with the result that data exfiltration and ransomware attacks succeed."}),ft.jsx("p",{className:"manifesto-text",children:"The self-writing internet will allow anyone with an internet-connected smartphone to create online functionality. While creating complicated apps and services demands clear and accurate prompting in conversation with AI, nonetheless, a significant portion of the 5 billion people with connected devices will be able to create simple apps for personal use, reflecting the scale of the empowerment that will occur."}),ft.jsx("p",{className:"manifesto-text",children:"The self-writing internet will increase the decentralization of tech and democratize the act of creation, but an important consideration is what self-writing might do to software engineering, UX, and design jobs. Our view is that, just like the internet, self-writing will create many new, high-value jobs."}),ft.jsx("p",{className:"manifesto-text",children:'Self-writing will lead to an enormous proliferation of apps and services, increasing their number by orders of magnitude. While most will be created without the involvement of traditional "craft" skills, a significant subset will benefit from human help, and eventually the sheer volume of new apps and services being created will drive an overall increase in demand for skilled developers and designers.'}),ft.jsx("p",{className:"manifesto-text",children:"Outside the technical realm, the freedoms and economic gains delivered by self-writing will also create non-technical jobs. People will be empowered to become entrepreneurs, and their ventures will employ people in various roles. Businesses will become more efficient, driving economies, and governments will be empowered to use technology to provide better operating environments for their citizens, reducing friction and accelerating progress."})]}),ft.jsxs("section",{className:"manifesto-section",children:[ft.jsx("h2",{className:"manifesto-section-title",children:"Key Technical Challenges"}),ft.jsx("h3",{className:"manifesto-subtitle",children:"Introduction"}),ft.jsx("p",{className:"manifesto-text",children:"Realizing the self-writing internet vision involves overcoming unique technological challenges. However, the solutions are already here, and the self-writing internet is now working in compelling initial forms, and in use – with broad public adoption imminent. Before proceeding to highlight what is already working, we must consider the key challenges."}),ft.jsx("p",{className:"manifesto-text",children:"Firstly, the self-writing internet requires powerful foundational AI models that can write code. Stunning advances have already been made by the AI industry in this regard, and progress continues, with major hosted solutions including ChatGPT, Claude and Gemini, and major open source solutions including models like DeepSeek and Llama, which can be self-hosted, and arbitrarily tweaked and fine tuned for purpose. But having models write code effectively is only one challenge."}),ft.jsx("p",{className:"manifesto-text",children:"Broadly speaking, there are two major additional challenges. The first involves providing AI with its own programming environment, which is specialized to support the efficient and error-free creation of self-writing app functionality, which are additionally able to ensure that mistakes by AI do not result in catastrophes – such as data loss during app upgrades. The second involves providing AI with platforms where user apps can be deployed that remove the need for human support in critical areas such as cybersecurity and resilience."}),ft.jsx("p",{className:"manifesto-text",children:"Overall, reconnoitering the key challenges involved, it's clear that effective self-writing will likely always involve the use of completely new technology stacks that are specialized for purpose."}),ft.jsx("p",{className:"manifesto-text",children:"To facilitate the full self-writing vision, these new specialized stacks should also make the creation of sovereign apps possible."}),ft.jsx("h3",{className:"manifesto-subtitle",children:"Security and Resilience"}),ft.jsx("p",{className:"manifesto-text",children:"Within the context of self-writing, a key challenge with traditional technology stacks is that they are insecure by default. When we build app functionality on these stacks, we must also make them secure ourselves. To achieve this, we create layer upon layer of defenses, by carefully configuring platform components such as databases and web servers and cloud frameworks such as Kubernetes to harden them for security purposes."}),ft.jsx("p",{className:"manifesto-text",children:"We then augment our hardened traditional stacks with cybersecurity defenses such as firewalls and intrusion monitoring, check third-party software doesn't have malicious logic hiding inside using anti-malware, and try to keep software packages up-to-date by installing security patches."}),ft.jsx("p",{className:"manifesto-text",children:"One simple mistake, or the minor failure of a cybersecurity system, can result in penetration by hackers and the exfiltration of sensitive data and systems being encrypted by ransomware. Furthermore, every day the cybersecurity challenge grows as hackers ironically learn how to employ AI for their own purposes."}),ft.jsx("p",{className:"manifesto-text",children:"The process of securing traditional technology stacks is so complicated that millions of pages of technical literature have been written to assist practitioners. This is a lot of responsibility to delegate to AI models that make regular mistakes."}),ft.jsx("p",{className:"manifesto-text",children:"However, even if AI could be trusted with such responsibilities, the task of managing security would slow down AI, perhaps preventing it working at chat speed, degrading the self-writing experience."}),ft.jsx("p",{className:"manifesto-text",children:"Resilience is another problem when building on traditional stacks. Craft engineers must invest time designing failover systems and other mechanisms to ensure apps stay online, and upgrades are often an all-hands-on-deck process, involving tricky synchronization as databases are reconfigured, and custom code is swapped in, and personnel must stand ready to rollback changes if something goes wrong."}),ft.jsx("p",{className:"manifesto-text",children:"On traditional stacks, implementing resilient apps, and performing app upgrades are major undertakings."}),ft.jsx("p",{className:"manifesto-text",children:"Today, more than 5 billion people have internet-connected smartphones. The huge volume of new custom apps that self-writing may create means traditional stacks cannot be used since security and resilience cannot depend on human assistance."}),ft.jsx("h3",{className:"manifesto-subtitle",children:'"Orthogonal Persistence." What the heck!?'}),ft.jsx("p",{className:"manifesto-text",children:'"Orthogonal persistence" is a technical-sounding term for a bleeding-edge software technology that greatly simplifies the production of apps and software. Among its aims and purposes, it focuses development on the essence of "what" must be created, while greatly reducing work that relates to "how" systems are put together.'}),ft.jsx("p",{className:"manifesto-text",children:'Generally speaking, creating apps involves work that can be divided into "what" and "how" buckets. The "what" involves the user experience people interact with, and the essential processing of data, which define the essence of the app. "How" applies to the actual process of combining custom code with platform building blocks, like databases, web servers, and cloud orchestration frameworks. "How" is concerned with the way technology stacks produce the overall systems that support apps, rather than the implementation of the functionality that defines them per se.'}),ft.jsx("p",{className:"manifesto-text",children:'A significant problem with traditional tech stacks is that building often involves far more investment into "how" than "what." In fact, as many developers will attest, project work often directs more than 90% of effort towards "how," with only 10% going towards "what."'}),ft.jsx("p",{className:"manifesto-text",children:'Oftentimes, this is caused by complications in the app logic resulting from the need to marshal data in and out of stores like databases, and other times from difficulties making different platform components interoperate, which lead to age-old problems such as "dependency hell," and other forms of problem ladder that require human intervention to solve.'}),ft.jsx("p",{className:"manifesto-text",children:'Zooming out to consider the needs of AI working solo in the self-writing setting, in which AI must create sophisticated functionality at the speed of chat, we can see that enabling AI to focus mainly on "what" will enable it to work far faster. In addition, removing the complications of "how" will allow functionality to be produced without errors on first pass more often, and free precious space from the inference context window, further increasing AI\'s effectiveness.'}),ft.jsx("p",{className:"manifesto-text",children:'Of course, the desire to reduce the cost of "how" is not new. Within the realm of traditional tech stacks, this is reflected in the increasing popularity of serverless cloud platforms, such as AWS Lambda, where developers create code that runs within a seamless universe, in which the underlying server instances are abstracted away, and elements of the scaling, security and resilience challenges are handled for them.'}),ft.jsx("p",{className:"manifesto-text",children:"However, these environments do not address the challenge of accessing and persisting (i.e. storing) data, and the serverless code has to call out into things like database servers."}),ft.jsx("p",{className:"manifesto-text",children:'Orthogonal persistence is a new technical approach that involves an important inventive step that collapses the conceptual distance between serverless logic and data, almost making them one and the same. This dramatically reduces the "how" involved in software development.'}),ft.jsx("p",{className:"manifesto-text",children:"When serverless software is written for an orthogonal persistence environment, its data automatically persists within its own logical abstractions. More concretely, data lives within its own variables, data types, and collections. Creating platforms supporting orthogonal persistence involves advanced computer science, but using it greatly simplifies software development."}),ft.jsx("p",{className:"manifesto-text",children:"Simplification enables AI to work faster, and go further without hitting limits. Furthermore, it also makes verification of its work – by human or machine – easier. Therefore, orthogonal persistence can play an extremely important role within self-writing environments."}),ft.jsx("p",{className:"manifesto-text",children:"Developers interested in seeing what orthogonal persistence looks like in code can take a look at this network app that stores files for users (the link opens an online-IDE):"}),ft.jsx("p",{className:"manifesto-text",children:ft.jsx("a",{href:"https://icp.ninja/editor?t=NL8c",target:"_blank",rel:"noopener",children:"https://icp.ninja/editor?t=NL8c"})}),ft.jsx("h3",{className:"manifesto-subtitle",children:"A New Tech Stack For Self-Writing"}),ft.jsx("h4",{className:"manifesto-subsubtitle",children:"The Internet Computer (and Internet Computer Protocol)"}),ft.jsx("p",{className:"manifesto-text",children:"The good news for those interested in the self-writing vision, is that the first real solution has already emerged as the result of a major ongoing R&D effort."}),ft.jsx("p",{className:"manifesto-text",children:'The DFINITY Foundation, a Swiss not-for-profit founded in 2016 (after the DFINITY project was announced in the summer of 2015) has pursued a special form of the general "World Computer" vision.'}),ft.jsx("p",{className:"manifesto-text",children:"The World Computer vision involves decentralized networks hosting code and data, and extending the public internet so that it can host apps and services natively, from simple functionality used for personal purposes, through social networks, enterprise systems, and financial ecosystems – removing the need to use servers and proprietary cloud services and avoiding dependencies and lock-in."}),ft.jsx("p",{className:"manifesto-text manifesto-text-highlight",children:'By 2025, DFINITY had spent approximately $500m, mostly on the complex computer science and engineering work involved in a public network known as the "Internet Computer."'}),ft.jsx("p",{className:"manifesto-text",children:'The Internet Computer is a decentralized network created by a protocol called "Internet Computer Protocol" (or ICP). This combines thousands of specialized computers from around the world, which are dedicated to purpose, that are owned and operated at scale by independent "node providers" (which comprise companies, financial institutions and individuals) from traditional data centers.'}),ft.jsx("p",{className:"manifesto-text",children:"ICP combines these machines to create a single seamless serverless cloud environment, by building on advanced mathematics, and the decentralization of the hardware. Because the environment is created by a mathematically secure network, it brings numerous special properties."}),ft.jsx("p",{className:"manifesto-text",children:'Thanks to the power of mathematics and advanced computer science, apps can run on the Internet Computer, end-to-end, without the need for cybersecurity protections because the network makes them "tamperproof." Even social media services that maintain pools of digital assets, so that users can transfer them using novel mechanisms like chat, have run successfully in production without the need for cybersecurity measures despite the highly hostile threat environment that the public internet presents.'}),ft.jsx("p",{className:"manifesto-text",children:'The mathematical ICP protocol imbues the Internet Computer with a property called "Byzantine Fault Tolerance," which provides hard security guarantees, so long as a sufficient proportion of its underlying node hardware (the machines the protocol combines to create the network and serverless cloud environment) do not fall under the control of attackers. Sans mistakes in the implementation of the special "client software" that nodes run to perform their role in the ICP network, hackers cannot break the platform provided by the network, since the laws of mathematics are firm (e.g., 2+2=5 can never be true).'}),ft.jsxs("p",{className:"manifesto-text",children:["If you are interested in the computer science that makes this possible, you can find a collection of papers at:"," ",ft.jsx("a",{href:"https://dfinity.org/tech/papers",target:"_blank",rel:"noopener",children:"https://internetcomputer.org/library"})]}),ft.jsx("p",{className:"manifesto-text",children:'Another powerful property of the environment relevant to solving resilience needs within the self-writing setting, is that the correct software logic of hosted apps is guaranteed to run, and their data is guaranteed to be available, so long as a sufficient proportion of the network\'s underlying nodes are operating correctly, for which reason some term them as being "unstoppable."'}),ft.jsx("p",{className:"manifesto-text",children:"Within the context of self-writing, removing the need to consider security and resilience lifts an enormous burden from AI working solo without human assistance. But the Internet Computer goes further."}),ft.jsx("p",{className:"manifesto-text",children:'One of the key aims of the Internet Computer, has always been to reinvent the nature of software, solving for the complexity involved with developing apps on traditional software stacks, which are centralized in nature. By leveraging unique aspects of the way the cloud is created, the Internet Computer provides a serverless environment with "orthogonal persistence," which is exactly what AI needs.'}),ft.jsx("p",{className:"manifesto-text manifesto-text-highlight",children:'The Internet Computer project saw the importance of self-writing, and that self-writing platforms would become the technology stacks of the future. Since self-writing speaks to key aims of the World Computer vision, the project focused efforts around realizing the self-writing internet. As work progressed, "Internet Computer 2.0" was born.'}),ft.jsx("p",{className:"manifesto-text",children:"Since inception, developers have been able to write backend code that runs on the Internet Computer in popular programming languages that compile to WebAssembly (a public standard for virtual machines and low-level bytecode format). However, since 2018, DFINITY has also developed its own programming language and accompanying framework, which is specialized for the Internet Computer environment, called Motoko."}),ft.jsx("p",{className:"manifesto-text manifesto-text-highlight",children:"It was decided that the Motoko programming language and framework would be developed to meet the needs of AI writing code, as well as human developers. Motoko became the first programming language designed to satisfy the unique needs of AI."}),ft.jsx("p",{className:"manifesto-text",children:'Motoko now supports an advanced form of orthogonal persistence, which is known as "enhanced orthogonal persistence." The framework requires that AI must upgrade apps by supplying special "migration logic," to mutate existing logic and associated data, into the new form.'}),ft.jsx("p",{className:"manifesto-text",children:"Thanks to advanced computer science, the Motoko framework provides self-writing platforms with hard guarantees that mistakes made by AI during upgrades will not result in accidental data loss. Now, instead of a data loss catastrophe, mistakes by AI simply result in a retry."}),ft.jsx("p",{className:"manifesto-text",children:"Motoko also enables AI to write and build the backend code for apps with unparalleled speed, and while new programming concepts are involved, AI has no problem ingesting training data during fine tuning to become an expert."}),ft.jsx("h4",{className:"manifesto-subsubtitle",children:"Caffeine"}),ft.jsx("p",{className:"manifesto-text",children:"Caffeine is the first platform for creating, updating, and managing self-writing apps, which either deploy to the Internet Computer, or a private network variant known as a UTOPIA. A growing team now works to advance the technology."}),ft.jsx("p",{className:"manifesto-text",children:"Caffeine is accessed as a web app that has been optimized for both desktop and mobile. In general form, it resembles a chat app, since creating online functionality now involves a conversation with AI. Its mission is to enable anyone who can effectively communicate in natural language, to build and maintain online functionality. It is designed to address the full spectrum of use cases, from consumer to enterprise."}),ft.jsx("p",{className:"manifesto-text",children:"Apps can be created that integrate with outside services, such as payment platforms, enabling important use cases like e-commerce. The Internet Computer also enables apps to trustlessly interoperate with major public blockchains, supporting the creation of Web3 functionalities that involve token processing. As work continues, Caffeine will be able to create apps for an ever-widening array of purposes."}),ft.jsx("p",{className:"manifesto-text",children:"A key feature of Caffeine is that it has its own App Store, which allows anyone to publish their apps for others to clone, either for free, or for a price. Users can visit the App Store to clone an app either as the starting point for a new project, or for immediate use."}),ft.jsx("p",{className:"manifesto-text",children:"The App Store provides foundations for a self-writing economic ecosystem, enabling diverse talent around the world to become industrious in a new way, and unleashing creativity that drives the production of apps that can be cloned for use."}),ft.jsx("p",{className:"manifesto-text",children:"In an interesting novel development, users can subscribe to updates that app publishers make, while still applying customizations."}),ft.jsx("p",{className:"manifesto-text",children:"The world of technology now approaches an interesting inflection point."})]}),ft.jsxs("section",{className:"manifesto-section",children:[ft.jsx("h2",{className:"manifesto-section-title",children:"Get Involved"}),ft.jsx("p",{className:"manifesto-text",children:"Caffeine is available to the public. Anyone can sign up for free and start creating apps and websites through conversation."})]})]})]})})})]})}finally{e.f()}}},{route:Bk.TermsOfUse,element:function(){var e=Xd(1);try{return ft.jsxs(yU,{title:"Caffeine AI Terms of Use",date:"Effective Date: December 17, 2025",children:[ft.jsxs(xU,{title:"1. Acceptance of Terms of Use",children:[ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:["By accessing or using the Caffeine AI website at"," ",ft.jsx(GU,{href:Bk.Home,children:"https://caffeine.ai/"})," (the “Site”) or any related pages or resources, you (the “User”) agree to be bound by these Terms of Use (the “Terms”),"," ",ft.jsx("strong",{children:" including the class action waiver and arbitration clause found in Section 12 below,"}),", and by the ",ft.jsx(GU,{href:`${Bk.License}`,children:"Caffeine License Agreement"})," (the “License Agreement”), which governs use of the Caffeine AI tool. If you do not agree, you must not use the Site or Caffeine."]}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"“We”, “Us”, or “Caffeine Labs” means Caffeine Labs AG, a Swiss corporation, and its subsidiaries and affiliates. Caffeine Labs has its registered office noted below."}),ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:["Your use of the Site and Caffeine AI is also subject to our"," ",ft.jsx(GU,{href:`${Bk.PrivacyPolicy}`,children:"Privacy Policy"}),"."]})]}),ft.jsxs(xU,{title:"2. About Caffeine AI",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Caffeine AI (“Caffeine”) is developed and operated by Caffeine Labs."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Caffeine is a platform for creating, updating, and managing self-writing applications that may be deployed to the Internet Computer or a private network variant known as UTOPIA. It is provided as a web application optimized for desktop and mobile and generally functions through a chat-style interface that enables users to build online functionality via natural language interaction with AI."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Caffeine’s purpose is to enable individuals and organizations to build, maintain, and evolve online applications. Applications may integrate with third party external services (e.g. payment platforms and recruiting management platforms) and, through the Internet Computer, interoperate with major public blockchains. The platform includes an App Store where users can publish applications for others to clone for free or for a fee. Caffeine Labs may update, enhance, or modify Caffeine at any time."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Information provided on the Site is for general informational purposes only. It does not constitute legal, financial, or technical advice, and should not be relied upon as such."})]}),ft.jsxs(xU,{title:"3. Use of the Site",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"You agree to use the Site only in compliance with these Terms, applicable law, and our policies. You must not use the Site in a way that could damage, disable, or impair it or interfere with its operation; attempt to gain unauthorized access to Caffeine or its systems; use the Site to transmit unlawful, harmful, or infringing material."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Specifically, you are prohibited from using the Site or its content: (a) to solicit others to perform or participate in any unlawful acts; (b) to violate any international, federal, provincial or state regulations, rules, laws, or local ordinances; (c) to infringe upon or violate our intellectual property rights or the intellectual property rights of others; (d) to harass, abuse, insult, harm, defame, slander, disparage, intimidate, or discriminate based on gender, sexual orientation, religion, ethnicity, race, age, national origin, or disability; (e) to submit false or misleading information; (f) to upload or transmit viruses or any other type of malicious code that will or may be used in any way that will affect the functionality or operation of the Sites or the Internet Computer; (g) to collect or track the personal information of others; (h) to spam, phish, pharm, pretext, spider, crawl, or scrape; (i) for any obscene or immoral purpose; or (j) to interfere with or circumvent the security features of the Site. We reserve the right to terminate your use of the Site for violating any of the prohibited uses."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Use of the Caffeine AI tool itself is governed by the License Agreement, including restrictions on prompt content and data submission."})]}),ft.jsx(xU,{title:"4. Payments and Refunds ",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"The Site may contain links to third party payment platforms such as Stripe where you can purchase subscription plans for credits as described on the Site. When using such third party payment platforms such as Stripe, those platforms process your payments and you agree to their applicable terms and conditions, in addition to the terms contained herein. All paid subscriptions are non-refundable and may not be redeemed for cash or other items of value. Subscription plans described on the Site may be updated from time to time."})}),ft.jsx(xU,{title:"5. Third-Party Links and Resources",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"The Site may contain links to external websites or resources operated by third parties. Caffeine Labs is not responsible for the availability, accuracy, or content of those sites and does not endorse or assume any liability for them. Access to third-party resources is at your own risk."})}),ft.jsxs(xU,{title:"6. Intellectual Property",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"All design, text, graphics, logos, software, and other materials provided to you by Caffeine on the Site are owned by Caffeine Labs or its licensors and are protected by intellectualproperty laws. Except as expressly permitted in these Terms or the License Agreement, no rights or licenses are granted."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Reproduction, distribution, or public display of the Site or Caffeine without Caffeine Labs’ prior written consent is prohibited."})]}),ft.jsx(xU,{title:"7. Warranty Disclaimer ",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"To the maximum extent permitted by law, the Site and all related content are provided “as is” and “as available” without any warranty of any kind, whether express or implied. Caffeine Labs does not warrant that the Site will be error-free, secure, or uninterrupted, or that any information provided is accurate or complete."})}),ft.jsxs(xU,{title:"8. Limitation of Liability",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"To the maximum extent permitted by applicable law, Caffeine Labs and its affiliates shall not be liable for any indirect, incidental, consequential, special, or punitive damages arising from or relating to your use or inability to use the Site or its content, even if Caffeine Labs has been advised of the possibility of such damages."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Nothing in these Terms excludes or limits liability for Caffeine Labs’s gross negligence, willful misconduct, or liability that cannot be excluded under Swiss law."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Caffeine Labs’s aggregate liability for all claims arising out of or related to these Terms or the use of the Site shall, to the maximum extent permitted by law, be limited to the total amount paid by the User to Caffeine Labs for access to Caffeine in the twelve (12) months preceding the event giving rise to the claim."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"You agree to indemnify and hold Caffeine Labs harmless from and against any claims, losses, or expenses (including reasonable legal fees) arising from your misuse of the Site or violation of these Terms, to the extent permitted by law."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"If you use the Caffeine AI tool, the limitations and exclusions set out in the License Agreement also apply."})]}),ft.jsx(xU,{title:"9. Availability and Modification of the Service",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Caffeine Labs does not guarantee continuous availability of the Site or Caffeine. Access may be interrupted for maintenance, updates, or other reasons. Caffeine Labs reserves the right to modify or discontinue the Site or the Caffeine AI tool (or any part of it) at any time without notice."})}),ft.jsx(xU,{title:"10. Changes to the Terms ",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Caffeine Labs may update these Terms from time to time, for example to reflect changes in services or applicable law. Updated Terms will be posted on the Site with a new effective date. Continued use after changes are posted constitutes acceptance of the revised Terms."})}),ft.jsx(xU,{title:"11. Governing Law and Jurisdiction",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"These Terms and any dispute arising from or relating to them are governed by the laws of Switzerland, excluding its conflict-of-laws rules. The courts of Zug, Switzerland shall have exclusive jurisdiction, subject to appeal to the Swiss Federal Court."})}),ft.jsx(xU,{title:"12. Class Action Waiver and Arbitration",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"To the fullest extent permitted by applicable law, if you are a US resident, you agree that any dispute, claim, cause of action, or controversy arising out of or relating to the websites or these Terms of Use: (a) shall be settled by individual arbitration administered by the American Arbitration Association in accordance with its Commercial Arbitration Rules, and judgment on the award rendered by the arbitrator(s) may be entered in any court having jurisdiction thereof; and (b) shall be resolved individually, without resort to any form of class action."})}),ft.jsx(xU,{title:"13. Contact",children:ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:["Caffeine Labs AG",ft.jsx("br",{}),"Genferstrasse 11",ft.jsx("br",{}),"8002 Zurich",ft.jsx("br",{}),"Switzerland",ft.jsx("br",{}),"Email:"," ",ft.jsx("a",{href:"mailto:support@caffeine.ai",className:"text-text-secondary underline hover:text-text-secondary",children:"support@caffeine.ai"})]})})]})}finally{e.f()}}},{route:Bk.PrivacyPolicy,element:function(){var e=Xd(1);try{return ft.jsxs(yU,{title:"Caffeine AI Privacy Notice",date:"Last Updated: December 17, 2025",children:[ft.jsxs(xU,{title:"Introduction",children:[ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:['This Privacy Notice (“Notice”) describes how Caffeine Labs AG, a corporation established under Swiss laws, including its subsidiaries and affiliates (collectively, ”Caffeine Labs”, "we," "our," or "us"), processes personal data about you when you visit ',ft.jsx(GU,{href:Bk.Home,children:"https://caffeine.ai/"})," (the “Website”). Please read this Notice carefully to understand our practices regarding your personal data (sometimes referred to in various privacy laws as “personal information”)."]}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Caffeine Labs is the controller of your personal data. The contact details of our EU Representative can be found below under the “Contact Us” section below."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"This Notice does not apply to any other data processing, including, without limitation, personal data we collect via other websites that do not link to this Notice."})]}),ft.jsxs(xU,{title:"Source of Personal Data We Process",children:[ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:[ft.jsx("strong",{children:"Personal Data You Provide."})," We may process personal data you directly provide us when you visit the Website, subscribe to updates, request more information on the Website (such as your name and email address), or when you message us via Caffeine.ai."]}),ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:[ft.jsx("strong",{children:"Data We Process Automatically."})," We may automatically process certain data, including some that can be considered personal data, when you use our Website, such as your internet protocol (IP) address, mobile device identifier, browser type, browser user-agent, operating system, internet service provider, pages you visit before and after using the Website, time and date of your visit, information about the links you click and pages you view within the Website, and other standard server log information. We may collect such information via the use of cookies, pixel tags, local shared objects, and similar technologies to automatically collect this information. More information on our use of cookies can be found in our sections on Cookies below."]}),ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:[ft.jsx("strong",{children:"Communications."})," If you communicate with us (such as contacting customer support), or engage in our surveys or feedback requests, we collect the contents of such communications. We also collect details of communications that we send you (such as through emails), and information about your interaction with these communications. When you use the Caffeine AI tool, we may use anonymized or aggregated information you submit through the prompt to train the Caffeine AI tool to continue to improve its performance, but will not use personally identifiable information about you to train the tool."]}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"We do not share your personal data collected via the Website with third parties, except with those third party services, explained further below, which help us conduct our business or, in the case of third-party advertising or analytical cookies and pixels, with your consent."})]}),ft.jsxs(xU,{title:"Purpose of Processing",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"We process your personal data to provide, maintain, improve, and promote the Website, and to communicate with you. In particular:"}),ft.jsxs("ul",{className:"m-0 text-md text-text-secondary list-disc pl-6",children:[ft.jsx("li",{children:"To research, analyze and improve the Website’s performance "}),ft.jsx("li",{children:"To create a user account"}),ft.jsx("li",{children:"To identify and track visitors to our Website"}),ft.jsx("li",{children:"To send you marketing and information updates about Caffeine.AI at your request"}),ft.jsx("li",{children:"For safety, security, and fraud prevention of the Website"}),ft.jsx("li",{children:"To investigate, prevent, and detect prohibited or illegal activities and other security or technical issues"}),ft.jsx("li",{children:"To investigate, troubleshoot and respond to all customer support queries you send to us, which may include reviewing session details you had during your use of the Caffeine AI tool"}),ft.jsx("li",{children:"To comply with and to satisfy applicable law, regulation, legal process, or governmental request"}),ft.jsxs("li",{children:["To fulfil our"," ",ft.jsx(GU,{href:`${Bk.TermsOfUse}?goback=${Bk.PrivacyPolicy}`,children:"Terms of Use"})," and comply with our legal obligations"]}),ft.jsx("li",{children:"As necessary for our (or others’) legitimate interests, including our interests in providing a safe, efficient and personalised service to our users or the public, unless such processing outweighs any risks to your interests or fundamental rights or freedoms that require protection of your personal data"})]})]}),ft.jsxs(xU,{title:"Legal Basis for Processing",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"We process your personal data in accordance with applicable data protection laws, including the UK and EU General Data Protection Regulation, if:"}),ft.jsxs("ul",{className:"m-0 text-md text-text-secondary list-disc pl-6",children:[ft.jsx("li",{children:"You have given your consent,"}),ft.jsx("li",{children:"It is necessary for the performance of a contract with you or to take steps at your request prior to entering into a contract,"}),ft.jsx("li",{children:"It is necessary for compliance with legal obligations to which we are subject or"}),ft.jsx("li",{children:"It is necessary for the purposes of our legitimate interest or those of third parties in particular our legitimate interest to pursue the purposes described in this Notice"})]})]}),ft.jsxs(xU,{title:"Data Sharing and Recipients",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"We limit the disclosure of your personal data to others. However, we share personal data with people and businesses that help operate the Website and carry out our business (referred to as our third-party processors or service providers), and when we are legally permitted or required to do so. We also share personal data when an individual requests we share it."}),ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:[ft.jsx("strong",{children:"Authorized third parties."})," We may share your personal data with Third-Party Services who support the Website, such as customer service and support services (e.g., call centre, help desk or customer relationship management providers), finance and accounting services (e.g., accountants, banks, credit check agencies, insurers, payment processors or tax advisors), IT and telecommunications services (e.g., cloud service providers, data hosting centres, software providers, IT maintenance and support providers, electronic communication services providers, or network operators), recruiting management, marketing and sales services (e.g., marketing and advertising, social media platforms or other media companies)."]}),ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:[ft.jsx("strong",{children:"Professional advisors."})," We may disclose your personal data to lawyers, accountants, insurers, information security and forensics experts."]}),ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:[ft.jsx("strong",{children:"Competent law enforcement, government regulators and courts."})," We may disclose your personal data to respond to legal process, law enforcement requests, subpoenas, court orders, legal claims or government inquiries, to detect fraud, and to protect and defend the rights, interests, safety, and security of the Website, our affiliates, owner, users, or the public."]}),ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:[ft.jsx("strong",{children:"Potential or actual acquirers or investors and their professional advisors."})," We may share your personal data in connection with a substantial corporate transaction, such as the sale of a Website, a merger, consolidation, sale of certain assets, or in the unlikely event of bankruptcy."]}),ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:[ft.jsx("strong",{children:"With your consent."})," We may share data for any other purposes disclosed to you at the time we collect the data and pursuant to your consent."]})]}),ft.jsxs(xU,{title:"Cookies and Social Media",children:[ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:["You may be able to access Third-Party Services, such as social media or messaging services, through the Website or even while logged into those accounts, to share any information about your experience on the Website with others, but you must note that"," ",ft.jsx("strong",{children:"these services and how they function in relation to our Website may not be fully within our control."})," ","These Third-Party Services may be able to collect information about you, including your activity on the Website, and they may notify your connections on the Third-Party Services about your use of the Website, in accordance with their own privacy policies."," ",ft.jsx("strong",{children:"We encourage you to visit their websites and review their privacy and use policies, and adjust your privacy settings on their websites accordingly."})]}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"A cookie is a piece of information that is placed automatically on your computer’s hard drive when you access certain websites. The cookie uniquely identifies your browser to the server. Cookies allow us to store information on the server (for example language preferences, technical information, click or path information, etc.), to help make the web experience better for you, to conduct website analysis and website performance review, and to serve you with relevant advertisements."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Most web browsers are set up to accept cookies, although you can set your browser to refuse all cookies or to indicate when a cookie is being sent. Note, however, that some portions of the Website may not work properly if you refuse cookies."})]}),ft.jsx(xU,{title:"Do Not Track",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"We partner with third parties to display advertising on our websites or to manage our advertising on other websites. Our third-party partners use cookies, web beacons, LSOs, tags, scripts, and similar technologies to gather information about you over time and across different websites or applications to help predict your preferences and show you ads on sites across the Internet. If you wish to manage your cookie preferences directly with us, please make a request by contacting us."})}),ft.jsxs(xU,{title:"Third Country Transfers",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"If you are located in the EU/EEA/UK and we transfer your personal data to recipients in countries outside of your home jurisdiction (“Third Countries”), we apply the following safeguards to ensure the protection of your personal data is not undermined:"}),ft.jsxs("ul",{className:"m-0 text-md text-text-secondary list-disc pl-6",children:[ft.jsxs("li",{children:["For recipients in Third Countries with an “adequate level” of protection. You can find the current list of adequate Third Countries here:",ft.jsxs("ul",{className:"m-0 text-md text-text-secondary list-disc pl-6",children:[ft.jsxs("li",{children:["For Switzerland in Annex 1 to the Ordinance on Data Protection:"," ",ft.jsx("a",{href:"https://www.fedlex.admin.ch/eli/cc/2022/568/en",className:"text-text-secondary underline hover:text-text-secondary",target:"_blank",rel:"noopener noreferrer",children:"https://www.fedlex.admin.ch/eli/cc/2022/568/en"})]}),ft.jsxs("li",{children:["For the EU:"," ",ft.jsx("a",{href:"https://ec.europa.eu/info/law/law-topic/data-protection/internationaldimension-data-protection/adequacy-decisions_en",className:"text-text-secondary underline hover:text-text-secondary",target:"_blank",rel:"noopener noreferrer",children:"https://ec.europa.eu/info/law/law-topic/data-protection/internationaldimension-data-protection/adequacy-decisions_en"})]})]})]}),ft.jsxs("li",{children:["For recipients in Third Countries without an “adequate level” of protection, we usually rely on standard contractual clauses (you can find the text of the standard contractual clauses here:"," ",ft.jsx("a",{href:"https://ec.europa.eu/info/law/law-topic/dataprotection/international-dimension-data-protection/standard-contractualclauses-scc_en",className:"text-text-secondary underline hover:text-text-secondary",target:"_blank",rel:"noopener noreferrer",children:"https://ec.europa.eu/info/law/law-topic/dataprotection/international-dimension-data-protection/standard-contractualclauses-scc_en"})," ","and if necessary on the UK Addendum (you can find the text of the UK Addendum here:"," ",ft.jsx("a",{href:"https://ico.org.uk/media2/migrated/4019535/addendum-international-data-transfer.docx",className:"text-text-secondary underline hover:text-text-secondary",target:"_blank",rel:"noopener noreferrer",children:"https://ico.org.uk/media2/migrated/4019535/addendum-international-data-transfer.docx"})," ",". The EU SCC are also applicable under the Swiss FADP."]}),ft.jsxs("li",{children:["For recipients in third countries without an “adequate level” of protection, and in the absence of standard contractual clauses, we rely on derogations, for example, if:",ft.jsxs("ul",{className:"m-0 text-md text-text-secondary list-disc pl-6",children:[ft.jsx("li",{children:"you have given your explicit consent,"}),ft.jsx("li",{children:"it is necessary for the conclusion or performance of a contract with you or in your interests, or"}),ft.jsx("li",{children:"it is necessary to establish, exercise, or defend legal claims."})]})]})]}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"For more details about our Third Country transfers or copies of these safeguards please reach out to us via any of the methods in the below “Contact Us” section."})]}),ft.jsxs(xU,{title:"Data Retention",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"We store your personal data for no longer than is necessary for the purposes described in this Notice. To determine our storage periods, we particularly use the following criteria:"}),ft.jsxs("ul",{className:"m-0 text-md text-text-secondary list-disc pl-6",children:[ft.jsxs("li",{children:["If you withdraw your consent or object to the processing of your personal data and we cannot rely on another legal basis, we will usually not store your personal data for any longer;"," "]}),ft.jsx("li",{children:"If we are legally obliged to retain your personal data, we will usually store your personal data for the prescribed retention period;"}),ft.jsx("li",{children:"If we are legally obliged to delete your personal data, we will usually not store your personal data for any longer;"}),ft.jsx("li",{children:"If we need your personal data to establish, exercise, or defend legal claims, we will usually store your personal data for the statutory limitation period or until legal proceedings are concluded;"}),ft.jsx("li",{children:"If we have an existing relationship with you, we will usually store your personal data for the period of our relationship;"}),ft.jsx("li",{children:"If we likely need to use your personal data in the future, we will usually store your personal data for this anticipated period in the future."})]})]}),ft.jsxs(xU,{title:"Your Rights",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Under applicable data protection and privacy laws, you may have the following rights"}),ft.jsxs("ul",{className:"m-0 text-md text-text-secondary list-disc pl-6",children:[ft.jsxs("li",{children:[ft.jsx("strong",{children:"Right to withdraw consent:"})," you can withdraw your consent at any time;"]}),ft.jsxs("li",{children:[ft.jsx("strong",{children:"Right of access/know to personal data:"})," you can ask us to provide access to your personal data;"]}),ft.jsxs("li",{children:[ft.jsx("strong",{children:"Right to rectification/correction:"})," you can ask us to rectify inaccurate personal data or complete incomplete personal data;"]}),ft.jsxs("li",{children:[ft.jsx("strong",{children:"Right to erasure/delete:"})," you can ask us to delete your personal data;"]}),ft.jsxs("li",{children:[ft.jsx("strong",{children:"Right to restriction of processing:"})," you can ask us to restrict the processing of your personal data;"]}),ft.jsxs("li",{children:[ft.jsx("strong",{children:"Right to data portability:"})," you can ask us to transfer your personal data to you or to another recipient at your choice;"]}),ft.jsxs("li",{children:[ft.jsx("strong",{children:"Right to appeal:"})," you may have the right to appeal our decision regarding a request using the contact information below. Please use the same email address that you used to submit the initial privacy rights request when you submit your Request to Appeal and please add “Request to Appeal” in the subject line of the email. If you do not use the same email address, we cannot link your request to appeal to your initial privacy rights request."]}),ft.jsxs("li",{children:[ft.jsx("strong",{children:"Right to object:"})," you can object to the processing of your personal data."]})]}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"To exercise these rights, please contact us using the information below."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"We do not discriminate or retaliate against you if you choose to exercise these rights."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"You also may designate an authorized agent to make a request on your behalf. If you are submitting a request through an authorized agent, the authorized agent must provide us with your signed written permission stating that the agent is authorized to make the request on your behalf. Alternatively, your authorized agent may provide evidence of having power of attorney or acting as a conservator for you. We may also request that any authorized agents verify their identity and may reach out to you directly to confirm that you have provided the agent with your permission to submit the request on your behalf."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Please note that your rights can be restricted in certain situations. In such case, we will inform you of the restriction’s reason. If you have any concerns about how we process your personal data, we encourage you to let us know so we can try to resolve your concerns."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"The enforcement of your rights is governed by applicable data protection laws. In Switzerland, you can take civil action for a breach of your personal rights, file a criminal complaint for a breach of the Data Protection Act, or inform the Federal Data Protection and Information Commissioner. You may have this right if the data protection laws of a country other than Switzerland apply to you and if you think we have not complied with data protection laws, having the right to lodge a complaint with the competent supervisory authority. Under certain U.S. state privacy laws, to the extent applicable, you may also have the right to appeal this decision or to contact that State’s Attorney General if you have concerns about the results of the appeal."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Data solely retained for data backup purposes is principally excluded from these rights until it is restored to an active system or next accessed or used for a sale, disclosure, or commercial purpose."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"For requests under certain applicable US privacy laws, these rights may not apply to pseudonymous data if the information necessary to identify the individual is kept separately and is subject to controls that prevent access to the information. Pseudonymous data, for these purposes, is personal data that can no longer be attributed to a specific individual without the use of additional information, if the additional information is kept separately and is subject measures to ensure that personal data is not attributed to the specific individual."})]}),ft.jsxs(xU,{title:"Responding to Your Rights Request",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"When you exercise these rights and submit a request to us, we may verify your identity by asking you for the following pieces of information: your relationship with us, first and last name, email address, and place of residency."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"We cannot respond to your request or provide you with personal data if we cannot verify your identity or authority to make the request and confirm the personal data relates to you. Making a verifiable consumer request does not require you to create an account with us. We will use the personal data you provide to us when submitting a consumer request only to verify the requestor’s identity or authority to make the request."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Depending on your jurisdiction, we have between 30 and 90 days to respond to your request. If we require more time, we will inform you of the reason and extension period in writing."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Please note that depending on your jurisdiction (not applicable for EU/UK), we are only obligated to respond, free of cost, to requests from the same consumer up to two times in a 12-month period. Depending on your jurisdiction, after you have exceeded the applicable number of requests, we have the right to charge a reasonable fee for fulfilling the request. In addition, under the applicable state privacy law, and for the protection of your personal data, we may be limited in what personal data we can disclose."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Depending on your jurisdiction, we may maintain your rights requests for at least 2 years. This information will not be used for any other purpose except to review compliance processes; it will not be shared except as necessary to comply with a legal obligation."})]}),ft.jsxs(xU,{title:"Security",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"We implement reasonable and appropriate technical and organizational measures to protect your personal data against unauthorized access, alteration, disclosure, or destruction."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Unfortunately, the transmission of information is not completely secure. Although we do our best to protect your personal data, we cannot guarantee the security of your personal data. Any transmission of personal data is at your own risk. We are not responsible for circumvention of any privacy settings or security measures."})]}),ft.jsxs(xU,{title:"Miscellaneous",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"Provision of your personal data may be necessary for us to fulfil our contractual obligations or to comply with statutory requirements. In some instances, providing personal data is required to enter into or perform our contract; if you choose not to provide such information, we may be unable to provide you with certain services or fulfil our obligations under the contract."}),ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"We do not engage in automated decision-making, including profiling, that produces legal effects or similarly significant consequences for you. Should this practice change, we will update this Notice to provide clear information about the logic involved, as well as the significance and envisaged consequences for you."})]}),ft.jsx(xU,{title:"Shine the Light Law",children:ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:['California\'s "Shine the Light" law (Civil Code Section § 1798.83) permits users of our Websites that are California residents to request certain information regarding our disclosure of Personal Information to third parties for their direct marketing purposes. To make such a request, please send an email to',ft.jsx("a",{href:"mailto:support@caffeine.ai",className:"text-text-secondary underline hover:text-text-secondary",children:"support@caffeine.ai"}),"."]})}),ft.jsx(xU,{title:"Changes to This Notice",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:'We may update this Notice from time to time. We will notify you of any changes by contacting you at your contact details provided to us and/or posting the new Notice on this page and updating the "Last Updated" date.'})}),ft.jsx(xU,{title:"Children's Privacy",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"The Website is not directed to children under 18. We do not knowingly collect personal data from children under 18 without parental consent."})}),ft.jsx(xU,{title:"Third-Party Links",children:ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"The Website may include links to third-party websites, plug-ins, and applications. Clicking on those links or enabling those connections may allow third parties to collect or share data about you. We do not control third-party websites and are not responsible for their privacy statements. If you submit personal data to any third-party websites or service providers, your information is governed by their privacy policies. When you leave our websites, we encourage you to read the privacy policies on every website you visit."})}),ft.jsx(xU,{title:"Social Media",children:ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:["We may also include applications or widgets from social media providers that allow interaction or content sharing by their users. These widgets, such as a Facebook “Share” or “Like” button, may be visible to you on our Website. Integration between our Website and social media networks such as Facebook, X and others may allow social media networks in which you participate to collect information about you, even when you do not explicitly activate the network’s application or widget."," ",ft.jsx("strong",{children:"Please visit the applicable social media network’s privacy policy to better understand their data collection practices and choices they make available to you."})," ","The privacy policy of the social media network controls the collection, use and disclosure of all personal data transmitted to that network."]})}),ft.jsxs(xU,{title:"Contact Us",children:[ft.jsx("p",{className:"m-0 text-md text-text-secondary",children:"If you have any questions about this Notice or our practices, please contact us at:"}),ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:["Caffeine Labs AG",ft.jsx("br",{}),"Genferstrasse 11",ft.jsx("br",{}),"8002 Zurich",ft.jsx("br",{}),"Switzerland",ft.jsx("br",{}),"Email:"," ",ft.jsx("a",{href:"mailto:support@caffeine.ai",className:"text-text-secondary underline hover:text-text-secondary",children:"support@caffeine.ai"})]}),ft.jsxs("p",{className:"m-0 text-md text-text-secondary",children:["Caffeine’s EU representative for data protection matters is an external contact at Eversheds Sutherland Netherlands B.V., as appointed to handle GDPR compliance. You can contact this EU representative via email at"," ",ft.jsx("a",{href:"mailto:CaffeineEURepresentative@eversheds-sutherland.com",className:"text-text-secondary underline hover:text-text-secondary",children:"CaffeineEURepresentative@eversheds-sutherland.com"})," ",'or by post, ensuring "EU Representative" is included in the subject line.']})]})]})}finally{e.f()}}},{route:Bk.Promptathon,element:function(){var e=Xd(1);try{return ft.jsxs("div",{className:"flex flex-col overflow-x-hidden min-h-screen overflow-y-auto pt-0 sm:pt-[58px] text-text-primary",children:[ft.jsx(f8,{}),ft.jsx("main",{className:"flex-1 flex flex-col overflow-x-hidden relative z-10 pt-20",children:ft.jsx("div",{className:"z-10 w-full flex-1 flex justify-center items-start px-5 pt-5",children:ft.jsxs("div",{className:"flex flex-col items-start max-w-6xl mx-auto w-xl",children:[ft.jsx(RF,{className:"w-full mb-8 h-auto",src:"https://cdn.caffeine.ai/assets/promptathon-logo-Dgr7s2vm.png",alt:"Promptathon — Jan 28 – Feb 4, online",responsiveWidth:"480 sm:720 md:920 lg:1152",sizes:"(min-width: 1192px) 1152px, calc(100vw - 2.5rem)",loading:"eager"}),ft.jsxs("div",{className:"w-full mb-8 leading-6",children:[ft.jsx("p",{className:"italic text-3xl",children:"A new year is a chance to start again. New habits. New goals. New ways of thinking."}),ft.jsx("p",{children:'In this promptathon, you will build small, personal apps that help people change: habit trackers, reflection tools, goal planners, wellness companions—whatever your "new you" looks like.'}),ft.jsx("p",{children:"You don't need to code. You only need an idea."}),ft.jsx("p",{children:"Build something that helps someone become a little better version of themselves!"}),ft.jsx("h2",{className:"text-lg",children:"Details"}),ft.jsx("p",{children:"The promptathon is a one-week online build event."}),ft.jsxs("ul",{children:[ft.jsxs("li",{children:["The promptathon starts on"," ",ft.jsx("span",{className:"font-bold",children:"Wednesday, January 28, 08:30 AM PST, 17:30 CET"}),". Tune in on X or YouTube at that time for the start livestream"]}),ft.jsx("li",{children:"You build your app using Caffeine"}),ft.jsx("li",{children:"You submit your project before the deadline"}),ft.jsx("li",{children:"A jury evaluates the entries and selects winners"})]}),ft.jsx("h2",{className:"text-lg",children:"Sign up for free credits"}),ft.jsxs("p",{children:["Sign up to receive ",ft.jsx("span",{className:"font-bold",children:"20 free Caffeine credits"})," that you can use to build during the event. Signing up is ",ft.jsx("span",{className:"font-bold",children:"not required"})," to participate."]}),ft.jsx("p",{className:"text-center",children:ft.jsxs(cF,{as:"a",rank:"cta",size:"xl",href:"https://caffeine-ai.typeform.com/to/o0vYUHLq",target:"_blank",rel:"noreferrer",children:["Sign up",ft.jsx(Cj,{size:20})]})}),ft.jsx("h2",{className:"text-lg",children:"Prizes"}),ft.jsxs("p",{children:["Total prize pool: ",ft.jsx("span",{className:"font-bold",children:"$10,000"})]}),ft.jsxs("ul",{children:[ft.jsx("li",{children:"1st place: $5,000"}),ft.jsx("li",{children:"2nd place: $3,000"}),ft.jsx("li",{children:"3rd place: $2,000"}),ft.jsx("li",{children:"Consolation prizes for places 4–10"})]}),ft.jsx("h2",{className:"text-lg",children:"Rules"}),ft.jsxs("ul",{children:[ft.jsxs("li",{children:["Your project must be started ",ft.jsx("span",{className:"font-bold",children:"no earlier than January 28"}),". Existing or previously built projects are not allowed."]}),ft.jsx("li",{children:"The app must be created using Caffeine, live and functional at the time of review."}),ft.jsx("li",{children:"One submission per participant."}),ft.jsx("li",{children:"Participant must be over 18 years old and not a resident of, citizen, or located in a geographic area that is subject to UN-, US-, EU-, Swiss or any other sovereign country sanctions or embargoes."}),ft.jsxs("li",{children:["Additional terms apply, see full"," ",ft.jsx(cA,{className:"gap-1!",iconAppend:ft.jsx(Vj,{size:"10"}),size:"lg",href:"https://docs.google.com/document/d/1f2cVOWf0n86ivV9HWFakBRxmrJcrUOXI/edit?usp=sharing&ouid=103662636926826566267&rtpof=true&sd=true",target:"_blank",children:"terms and conditions"}),"."]})]})]})]})})}),ft.jsx(g8,{})]})}finally{e.f()}}},{route:Bk.CreatorProgram,element:function(){var e=Xd(1);try{return ft.jsx("div",{className:"terms-page",children:ft.jsx("div",{className:"terms-container",children:ft.jsx("div",{className:"terms-content",children:ft.jsxs("div",{className:"terms-card",children:[ft.jsx("h1",{className:"terms-title",children:"Caffeine Creator Program"}),ft.jsx("h2",{className:"section-title",children:"TERMS AND CONDITIONS"}),ft.jsx("p",{className:"section-text",children:'Caffeine Labs AG, including its subsidiaries and affiliates (collectively, the "Company") offers the Caffeine Creator Program (the "Creator Program") inviting Participants to catalyze the growth of the Caffeine.ai ecosystem by inspiring, engaging, and accelerating people to build complete apps and websites by chatting with AI. These Terms and Conditions (the "Terms") apply to your participation in the Creator Program, and in addition to any other Creator Program terms, describes the Creator Program\'s requirements as well as the benefits that you may receive as a participant in the Creator Program.'}),ft.jsx("p",{className:"section-text",children:"While all Project Proposals (defined below) submitted by you (as an applicant or after acceptance into the Creator Program by the Company) will be reviewed by the Company, your creation or release of a Project (defined below) or your engagement in any other Creator Program related activities, do not obligate the Company to provide you with Rewards (defined below) or any other Creator Program benefits."}),ft.jsx("p",{className:"section-text",children:ft.jsx("strong",{children:'YOUR PARTICIPATION IN THE CREATOR PROGRAM IS ENTIRELY VOLUNTARY, BUT IF YOU ARE PARTICIPATING IN THE PROGRAM, YOU MUST STRICTLY ADHERE TO THESE TERMS. IF, AS PART OF YOUR VOLUNTARY PARTICIPATION, YOU MEET THE CRITERIA LISTED BELOW AND ARE SELECTED AS A COMMUNITY CREATOR, YOU MAY RECEIVE CERTAIN AMOUNTS OF CASH AND/OR TOKENS ("INCENTIVES") (WHERE PERMITTED BY LAW). INCENTIVES ARE AWARDED AT THE SOLE DISCRETION OF THE COMPANY AND ARE NOT GUARANTEED. YOU ACCEPT ANY INCENTIVES KNOWING THAT YOU AGREE THAT ANY INCENTIVES RECEIVED BY YOU WILL BE FOR YOUR CONTRIBUTIONS FOR GROWING THE ADOPTION OF THE CAFFEINE ECOSYSTEM AS DEFINED BELOW AND AS PART OF THIS CREATOR PROGRAM.'})}),ft.jsxs("section",{className:"terms-section",children:[ft.jsx("h2",{className:"section-title",children:"1. Certain Definitions."}),ft.jsx("p",{className:"section-text",children:'"Participant" means all individuals and/or teams that submit an entry and participate in the Caffeine Creator Program.'}),ft.jsx("p",{className:"section-text",children:'"Intellectual Property Rights" means patent rights (including patent applications and disclosures), copyrights, trademarks, trade secret rights, work, and any other intangible property rights recognized in any country or jurisdiction in the world.'}),ft.jsx("p",{className:"section-text",children:'"Participant Marks" means the trademarks, service marks, trade names and logos for your entity\'s products and services.'}),ft.jsx("p",{className:"section-text",children:'"Participant Materials" means any materials, content or information provided by you (including your team members if applicable) to the Company in connection with the Caffeine Creator Program.'}),ft.jsx("p",{className:"section-text",children:'"Project" means the application materials and content that you submit (or desire to submit) to the Company for review and/or consideration by the Company for the Creator Program under these Terms.'}),ft.jsx("p",{className:"section-text",children:'"Project Proposal" means a general description of each proposed Project, which among other details, specifies the features of the applicable Project.'}),ft.jsx("p",{className:"section-text",children:'"Program Milestone" has the meaning given in Section 3.1.'}),ft.jsx("p",{className:"section-text",children:'"Company Materials" means all information and materials that may be provided to Participant by the Company in the course of the Creator Program and all Intellectual Property Rights thereto.'}),ft.jsx("p",{className:"section-text",children:'"Token" means the Internet Computer Protocol ("ICP") utility token, the native unit of value used to enable participation on the Internet Computer blockchain.'}),ft.jsx("p",{className:"section-text",children:'"Token Reward" means the eligible amount and type of Token which may be granted to Participants for participation in the Creator Program and/or completion of a Program Milestone in accordance with Section 3.'})]}),ft.jsxs("section",{className:"terms-section",children:[ft.jsx("h2",{className:"section-title",children:"2. Eligibility; Program Requirements."}),ft.jsx("h3",{className:"section-title",children:"2.1. Eligibility."}),ft.jsx("p",{className:"section-text",children:"You may only participate in the Caffeine Creator Program if:"}),ft.jsxs("ul",{className:"terms-list",children:[ft.jsx("li",{children:'You are over 18 years old or are the age of majority in the jurisdiction in which you reside at the time of your application submission; or a business, and in each case have registered with the Company and satisfied the "Program Requirements" set forth below;'}),ft.jsx("li",{children:"You are a resident of a jurisdiction where participation in the Creator Program is not prohibited by law;"}),ft.jsx("li",{children:"You are not a resident of, citizen, or located in a geographic area that is subject to UN-, US-, EU-, Swiss or any other sovereign country sanctions or embargoes;"}),ft.jsx("li",{children:"You, nor, if applicable, any third party entities that you represent (i) is listed or associated with any person or entity being listed on any of the US Department of Commerce's Denied Persons or Entity List, the US Department of Treasury's Specially Designated Nationals List, the EU Consolidated List of Persons, Groups and Entities Subject to EU Financial Sanctions or the Swiss SECO's Overall List of Sanctioned Individuals, Entities and Organizations, (ii) is a person identified as a terrorist organization or any other relevant lists maintained by any governmental authority;"}),ft.jsx("li",{children:"Your participation in the Caffeine Creator program is not in violation of any national, state, or local law or regulation applicable to you;"}),ft.jsx("li",{children:"You are not employed in any way by the Company or any of its affiliates and are not an immediate family member of anyone thereof;"}),ft.jsx("li",{children:"Your Entry is in English; and"}),ft.jsx("li",{children:"You comply with all anti-money laundering and anti-terrorist requirements, to the extent required by applicable laws, and successfully pass KYC, as applicable, according to a process that, in the sole discretion of the Company, is deemed sufficient."})]}),ft.jsx("h3",{className:"section-title",children:"2.2. Application."}),ft.jsx("p",{className:"section-text",children:"The Caffeine Creator Program is open to individuals and entities that have submitted a completed Creator Program application describing the Project Proposal, and have received a written notice from the Company indicating its acceptance of the application."}),ft.jsx("h3",{className:"section-title",children:"2.3. Acceptance."}),ft.jsx("p",{className:"section-text",children:"If accepted, you must confirm your agreed upon deliverables, as set forth in the Creator Program Site and in further instructions that may be provided to you by the Company."}),ft.jsx("h3",{className:"section-title",children:"2.4. Program Requirements."}),ft.jsx("p",{className:"section-text",children:"To participate in the Creator Program, you must do the following in accordance with any timelines communicated to you in writing by the Company:"}),ft.jsx("p",{className:"section-text",children:"(a) execute any additional terms or forms (e.g., W9 or W8-BEN) as may required by the Company; and"}),ft.jsx("p",{className:"section-text",children:"(b) comply with all Creator Program requirements as set forth in Sections 2.1, 2.2 and 2.3 above and all instructions and requirements as set forth in the Creator Program Site."}),ft.jsx("h3",{className:"section-title",children:"2.5 Entrant Guidelines."}),ft.jsx("p",{className:"section-text",children:"Entries may NOT contain, as determined by the Company, in its sole and absolute discretion, any content that:"}),ft.jsxs("ul",{className:"terms-list",children:[ft.jsx("li",{children:"is sexually explicit, unnecessarily violent or derogatory of any ethnic, racial, gender, religious, professional or age group;"}),ft.jsx("li",{children:"profane or pornographic;"}),ft.jsx("li",{children:"promotes alcohol, illegal drugs, tobacco (or the use of any of the foregoing) or a particular political agenda;"}),ft.jsx("li",{children:"defames, misrepresents or contains disparaging remarks about other people or companies;"}),ft.jsx("li",{children:"contains trademarks, logos, or trade dress, without express written consent of the rights holder(s) or a reasonably apparent lawful basis for your use(s);"}),ft.jsx("li",{children:"contains copyrighted materials owned by others (including photographs, sculptures, paintings, and other works of art or images published on or in websites, television, movies or other media) either without express written consent of the rights holder(s) or a reasonably apparent lawful basis for your use(s);"}),ft.jsx("li",{children:"communicates messages or images inconsistent with the positive images and/or good will to which Company wishes to associate; and/or violates any law;"}),ft.jsx("li",{children:"contains packaging or building (exteriors/interiors) owned by others."})]}),ft.jsx("p",{className:"section-text",children:"The Company reserves the right to investigate and verify, conditionally reject, or reject outright any Project, in our sole and absolute discretion, that we in good faith determine may not, or does not, meet the above criteria or any terms and conditions for this Creator Program."}),ft.jsx("h3",{className:"section-title",children:"2.6"}),ft.jsx("p",{className:"section-text",children:"All Participants grant the Company a royalty-free worldwide license and right in perpetuity to use their name, image, and likeness for the purposes of producing, promoting, and advertising the Creator Program, Caffeine.ai and the Caffeine ecosystem."})]}),ft.jsxs("section",{className:"terms-section",children:[ft.jsx("h2",{className:"section-title",children:"3. Program Milestones"}),ft.jsx("h3",{className:"section-title",children:"3.1. General."}),ft.jsxs("p",{className:"section-text",children:['To be eligible to receive any Incentives paid in U.S. Dollars (collectively with the Token Rewards, the "Rewards"), you must satisfy and complete the corresponding program milestone requirements (each a "Program Milestone"), which will be set following your acceptance to the program. Any completion of a Program Milestone requires review and approval by the Company, such approval to be determined by the Company in its sole discretion. No Program Milestone will be deemed completed and eligible for the applicable Rewards until you have received a written approval notice of your Program Milestone from the Company.'," ",ft.jsx("strong",{children:"THE GRANTING OF REWARDS AS PART OF THE CREATOR PROGRAM IS WITHIN THE COMPANY'S SOLE DISCRETION AND ALL DECISIONS RELATED TO THE PROGRAM ARE FINAL AND NON-APPEALABLE."})]}),ft.jsx("h3",{className:"section-title",children:"3.2. Additional Requirements."}),ft.jsx("p",{className:"section-text",children:"The Company may request additional information from you as may be necessary to review and/or consider your Project Proposal, and you must respond to any requests for additional information within three (3) business days from the time the request is made. You may forfeit any benefits, Rewards, and/or opportunities to proceed in the Creator Program if (i) the Company is unable to contact you or your designated representative within three (3) business days of first attempted notification, or (ii) you fail to respond within three (3) business days of notification. Rewards are granted without warranty of any kind from the Company, express or implied, without limitation. All applicable federal, state and local laws and regulations apply. You agree to be bound by the decisions of the Company, which are final and binding on all matters pertaining to the Creator Program."})]}),ft.jsxs("section",{className:"terms-section",children:[ft.jsx("h2",{className:"section-title",children:"4. Payments."}),ft.jsx("h3",{className:"section-title",children:"4.1. Payment of Rewards."}),ft.jsx("p",{className:"section-text",children:'Subject to these Terms, the Company shall pay Participant the Rewards specified for the completion of Project Milestones. Participants must perform the work in connection with the Creator Program at his or her own expense, and using his or her own resources and equipment. Participant acknowledges that the Rewards, milestones and schedule set forth in the Statement of Work (which is finalised between the Participant and the Company based on the original Project Proposal submitted in the application form, hereinafter referred to as "SOW") approved by the Company, represents Participant\'s entire reward with respect to these Terms and the Company will have no other obligation for any other compensation or expenses or costs incurred by Participant in connection with the performance of his/her obligations under these Terms unless otherwise agreed-upon in writing by the parties.'}),ft.jsx("h3",{className:"section-title",children:"4.2"}),ft.jsx("p",{className:"section-text",children:"The Rewards are granted without warranty of any kind from the Company, express or implied, without limitation."}),ft.jsx("p",{className:"section-text",children:ft.jsx("strong",{children:"THE GRANT OF ANY TOKENS TO PARTICIPANTS IS SUBJECT TO COMPLIANCE WITH APPLICABLE LAWS."})}),ft.jsx("h3",{className:"section-title",children:"4.3 Milestones."}),ft.jsxs("p",{className:"section-text",children:["The completion of a Project Milestone requires review and approval by the Company, such approval to be determined by the Company in its sole discretion. The Company, at its option, may provide Participant with its written quality standards for the Project and/or applicable Milestones. Participant agrees to use these standards, as well as additional guidance and suggestions which may be provided from time to time by the Company. Any or all Milestones must be satisfactory in the reasonable opinion of the Company, who retains the right to approve all such Milestones prior to completion and delivery. Without limiting the foregoing, Participant acknowledges and agrees that the Company's payment obligation will be expressly subject to Participant's delivery of each applicable Project Milestone as set forth in the applicable SOW. The approved SOW shall be made a part of and incorporated into these Terms."," ",ft.jsx("strong",{children:"THE GRANTING OF REWARDS AS PART OF THE PROGRAM IS WITHIN THE COMPANY'S SOLE DISCRETION AND ALL DECISIONS RELATED TO THE PROGRAM ARE FINAL AND NON-APPEALABLE."})]})]}),ft.jsxs("section",{className:"terms-section",children:[ft.jsx("h2",{className:"section-title",children:"5. Marketing and Promotion"}),ft.jsx("h3",{className:"section-title",children:"5.1. Publicity."}),ft.jsx("p",{className:"section-text",children:"You will not issue any press releases or similar public announcements in connection with these Terms (including statements regarding the terms and conditions of these Terms and the details of the Creator Program), without the prior written approval of the Company."}),ft.jsx("h3",{className:"section-title",children:"5.2. Publication in List."}),ft.jsx("p",{className